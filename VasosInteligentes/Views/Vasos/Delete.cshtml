@model VasosInteligentes.Models.Vaso

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

<h3>Tem certeza que você quer deletar?</h3>
<div>
    <h4>Vaso</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Nome)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Nome)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.PlantaId)
        </dt>
        <dd class = "col-sm-10">
            @if (Model.PlantaRelacionada != null && Model.PlantaRelacionada.Any())
            {
                <span>@Model.PlantaRelacionada.FirstOrDefault()?.Nome</span>
            }
            else
            {
                <span>Planta não encontrada.</span>
            }
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Localizacao)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Localizacao)
        </dd>
    </dl>
    
    <form asp-action="Delete" class="mt-4">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Voltar para vasos</a>
    </form>
</div>
