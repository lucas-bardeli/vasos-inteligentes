@model IEnumerable<VasosInteligentes.Models.Vaso>

@{
    ViewData["Title"] = "Meus Vasos";
}

<h1>Meus Vasos</h1>

<p>
    <a asp-action="Create">Criar novo Vaso</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Nome)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PlantaId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Localizacao)
            </th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Nome)
                </td>
                <td>
                    @item.PlantaRelacionada?.FirstOrDefault()?.Nome
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Localizacao)
                </td>
                <td class="mt-4">
                    <a asp-action="Edit" asp-route-id="@item.Id">Editar</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Detalhes</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Deletar</a>
                </td>
            </tr>
        }
    </tbody>
</table>
