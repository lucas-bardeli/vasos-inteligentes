            <a class="nav-link text-light" asp-area="" asp-controller="Vasos" asp-action="Index">Vasos</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-light" asp-area="" asp-controller="Users" asp-action="Index">Usuários</a>
        </li>
    }
}
