@model VasosInteligentes.ViewModel.ResetPasswordViewModel;
@{
    ViewData["Title"] = "Redefinir senha";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Troque sua senha</h1>
<div class="text-danger" asp-validation-summary="All"></div>

<form asp-action="ResetPassword">
    <input type="hidden" asp-for="Token" />
    <input type="hidden" asp-for="UserId" />

    <div class="form-group">
        <label asp-for="Email">E-mail</label>
        <input type="email" asp-for="Email" class="form-control" />
        <label asp-for="NewPassword">Senha</label>
        <input type="password" asp-for="NewPassword" class="form-control" />
        <label asp-for="ConfirmPassword">Confirme a Nova Senha</label>
        <input type="email" asp-for="ConfirmPassword" class="form-control" />

        <button type="submit" class="btn btn-primary">Enviar</button>
    </div>
</form>